# ─────────────────────────────────────────────────────────────────────────────
# WboxCLI environment template
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
#
# IMPORTANT: WboxCLI does NOT read `.env` at runtime in production.
# Credentials, LLM keys, and resume paths live in `~/.jobcli/jobcli.db`,
# managed by `wboxcli login`, `wboxcli resume-upload`, and `wboxcli config`.
#
# This file is only useful for local development or one-off scripts that
# explicitly load `python-dotenv`.
# ─────────────────────────────────────────────────────────────────────────────

# Whitebox Learning portal
WBOX_LOGIN_URL=https://whitebox-learning.com/login
WBOX_DASHBOARD_URL=https://whitebox-learning.com/user_dashboard

# ── LLM API keys ─────────────────────────────────────────────────────────────
# At least one provider is required. Rotate keys regularly.
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Job board credentials (optional) ─────────────────────────────────────────
JOBCLI_USERNAME=you@example.com
JOBCLI_PASSWORD=change-me

# ── LinkedIn credentials (optional) ──────────────────────────────────────────
LINKEDIN_USERNAME=you@example.com
LINKEDIN_PASSWORD=change-me

# ── Execution preferences ────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=openai
HEADLESS=false
MAX_RETRIES=3

# ── Resume paths ─────────────────────────────────────────────────────────────
# Use forward slashes (/) even on Windows.
RESUME_PDF_PATH=/absolute/path/to/your_resume.pdf
RESUME_JSON_PATH=/absolute/path/to/your_resume.json

# ── Database & logs ──────────────────────────────────────────────────────────
DATABASE_PATH=~/.jobcli/jobcli.db
LOG_DIRECTORY=logs

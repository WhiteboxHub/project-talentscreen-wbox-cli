include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include CODE_OF_CONDUCT.md
include pyproject.toml
include requirements.txt
include requirements-dev.txt
include .env.example

recursive-include src/jobcli *.py *.json *.yml *.yaml *.txt *.md
recursive-include config *.example.yml *.example.yaml

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.dylib
global-exclude .DS_Store
global-exclude .deepeval
prune .deepeval
prune logs
prune build
prune dist
prune venv
prune venv_old_314
prune .venv
prune .tmp_openclaw
prune extension_unpacked
prune snapshots
prune traces
prune telemetry
prune ai_reasoning
prune failure_reports
prune replay_sessions

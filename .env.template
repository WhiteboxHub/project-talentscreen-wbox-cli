# JobCLI Environment Configuration Template

# --- LLM API KEYS (At least one is required) ---
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# --- Execution Preferences ---
DEFAULT_LLM_PROVIDER=openai  # Options: openai, anthropic, gemini
HEADLESS=true                # Set to false to see the browser in action
MAX_RETRIES=3

# --- Resume Paths (Absolute paths recommended) ---
RESUME_PDF_PATH=C:/path/to/your/resume.pdf
RESUME_JSON_PATH=C:/path/to/your/resume.json

# --- Database & Logs ---
DATABASE_PATH=~/.jobcli/jobcli.db
LOG_DIRECTORY=logs

# --- Job Board Credentials (Optional) ---
# JOB_BOARD_USERNAME=your_username
# JOB_BOARD_PASSWORD=your_password
